# 部署环境变量模板：复制为 .env 后按需修改

# ===== 数据库（使用服务器上已有的 MySQL 容器）=====
# 容器通过 host.docker.internal 访问宿主机上映射的 MySQL 端口；一般无需修改
DB_HOST=host.docker.internal
DB_PORT=3306
# 数据库名（需在已有 MySQL 中预先创建空库，见 DEPLOY.md）
DB_NAME=CONSUMABLES
# 数据库用户名与密码（改为你现有 MySQL 的实际账号密码）
DB_USERNAME=root
DB_PASSWORD=HH123456

# ===== 前端 =====
# 前端对外访问端口（默认 8090，避免与服务器已有服务的 80 端口冲突）
WEB_PORT=8090
