<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.consumables.platform.account.mapper.AccountMapper">

    <resultMap id="accountResultMap" type="com.company.consumables.platform.account.entity.Account">
        <id column="S_ID" property="sId"/>
        <result column="S_TENANT_ID" property="sTenantId"/>
        <result column="S_LOGIN_NAME" property="sLoginName"/>
        <result column="S_PASSWORD" property="sPassword"/>
        <result column="I_ROLE" property="iRole"/>
        <result column="I_STATUS" property="iStatus"/>
        <result column="DT_CREATE_TIME" property="dtCreateTime"/>
        <result column="DT_UPDATE_TIME" property="dtUpdateTime"/>
        <result column="S_CREATE_USER" property="sCreateUser"/>
        <result column="S_UPDATE_USER" property="sUpdateUser"/>
    </resultMap>

    <insert id="insert" parameterType="com.company.consumables.platform.account.entity.Account">
        INSERT INTO TAB_ACCOUNT
        (S_ID, S_TENANT_ID, S_LOGIN_NAME, S_PASSWORD, I_ROLE, I_STATUS,
         DT_CREATE_TIME, DT_UPDATE_TIME, S_CREATE_USER, S_UPDATE_USER)
        VALUES
        (#{sId}, #{sTenantId}, #{sLoginName}, #{sPassword}, #{iRole}, #{iStatus},
         #{dtCreateTime}, #{dtUpdateTime}, #{sCreateUser}, #{sUpdateUser})
    </insert>

    <select id="selectByLoginName" resultMap="accountResultMap">
        SELECT S_ID, S_TENANT_ID, S_LOGIN_NAME, S_PASSWORD, I_ROLE, I_STATUS,
               DT_CREATE_TIME, DT_UPDATE_TIME, S_CREATE_USER, S_UPDATE_USER
        FROM TAB_ACCOUNT
        WHERE S_LOGIN_NAME = #{loginName}
    </select>

    <select id="countByLoginName" resultType="int">
        SELECT COUNT(*) FROM TAB_ACCOUNT WHERE S_LOGIN_NAME = #{loginName}
    </select>

    <delete id="deleteByTenantId">
        DELETE FROM TAB_ACCOUNT WHERE S_TENANT_ID = #{tenantId}
    </delete>

</mapper>
